{
    "name": "happenv-com/filament-multi-source-upload",
    "description": "Filament file upload field that accepts a local file or a URL, always materializing the file onto the target disk.",
    "license": "MIT",
    "keywords": [
        "filament",
        "laravel",
        "livewire",
        "file-upload",
        "url"
    ],
    "authors": [
        {
            "name": "webard",
            "email": "code@webard.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.7.0-beta2",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Happenv\\FilamentMultiSourceUpload\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Happenv\\FilamentMultiSourceUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Happenv\\FilamentMultiSourceUpload\\FilamentMultiSourceUploadServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    }
}
