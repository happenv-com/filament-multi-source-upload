{
    "name": "happenv-com/filament-multi-source-upload",
    "description": "Filament file upload field that accepts a local file or a URL, always materializing the file onto the target disk.",
    "license": "MIT",
    "keywords": [
        "filament",
        "laravel",
        "livewire",
        "file-upload",
        "url"
    ],
    "authors": [
        {
            "name": "webard",
            "email": "code@webard.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Happenv\\FilamentMultiSourceUpload\\": "src/",
            "Happenv\\FilamentMultiSourceUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Happenv\\FilamentMultiSourceUpload\\FilamentMultiSourceUploadServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
